name: NinjaxxGames
version: 1.0.0
main: com.ninjaxxgames.NinjaxxGames
api-version: '1.21'
author: CACA
description: CACA
softdepend: [PlaceholderAPI]
commands:
  ninjaxx:
    description: Commande principale du plugin NinjaxxGames
    usage: /ninjaxx <sous-commande>
    permission: ninjaxxgames.admin
    permission-message: "§cTu n'as pas la permission d'utiliser cette commande."

permissions:
  ninjaxxgames.admin:
    description: Permet d'administrer le plugin NinjaxxGames
    default: op
